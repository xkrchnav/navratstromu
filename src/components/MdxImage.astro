---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata | string;
  alt?: string;
  caption?: string;
  width?: number;
  height?: number;
  loading?: "lazy" | "eager";
  class?: string;
}

const {
  src,
  alt,
  caption,
  width,
  height,
  loading = "lazy",
  class: className = "",
} = Astro.props;

const getFileName = (value: ImageMetadata | string) => {
  const sourcePath = typeof value === "string" ? value : value.src;
  const rawSegment = sourcePath.split("/").pop() ?? "image";
  const fileName = rawSegment.split("?")[0]?.split("#")[0] ?? "image";
  return fileName.replace(/\.[^/.]+$/, "").replace(/[-_]+/g, " ").trim() || "image";
};

const fallbackText = getFileName(src);
const resolvedAlt = alt?.trim() || fallbackText;
const resolvedCaption = caption?.trim();
---

<figure class={`mdx-image ${className}`}>
  {
    typeof src === "string" ? (
      <img
        src={src}
        alt={resolvedAlt}
        loading={loading}
        width={width}
        height={height}
        class="mdx-image__media"
      />
    ) : (
      <Image
        src={src}
        alt={resolvedAlt}
        width={width ?? src.width}
        height={height ?? src.height}
        loading={loading}
        class="mdx-image__media"
      />
    )
  }
  {resolvedCaption && <figcaption class="mdx-image__caption">{resolvedCaption}</figcaption>}
</figure>

---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import blogHeroDemoImage from "../assets/blog/stare-odrudy-demo.svg";

const posts = await getCollection("blog");
const featuredPosts = posts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<BaseLayout
  title="Návrat stromků | Obnova sadů v Lysicích"
  description="Příběh paní Hedviky Horňanské a návratu ovocných stromů do Lysic a okolí."
>
  <section class="container-page py-12 md:py-20">
    <div class="grid items-center gap-8 md:grid-cols-2">
      <div>
        <p class="mb-3 text-base font-semibold uppercase tracking-wide text-earth">Návrat ovocných stromů</p>
        <h1 class="font-heading text-4xl leading-tight text-leaf md:text-6xl">
          Vracíme do Lysic stromy, které tam vždy patřily
        </h1>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-leaf md:text-xl">
          Příběh krajiny, paměti a odhodlání. Po letech necitlivého kácení se do zahrad vrací jabloně,
          hrušně i slivoně — s úctou k tradici a láskou k budoucnosti.
        </p>
        <a
          href="#kontakt"
          class="mt-8 inline-flex rounded-md bg-apple px-6 py-3.5 text-lg font-semibold text-white transition hover:bg-apple/90"
          >Spojit se s námi</a
        >
      </div>
      <div class="skeleton-image min-h-72">
        <span>Zde bude obrázek sadu</span>
      </div>
    </div>
  </section>

  <section class="container-page py-8 md:py-14">
    <div class="grid gap-8 md:grid-cols-[1.3fr_1fr] md:gap-10">
      <article class="rounded-xl border border-leaf/25 bg-white/70 p-6 shadow-sm">
        <h2 class="font-heading text-3xl text-leaf md:text-4xl">Příběh, který nesmí zmizet</h2>
        <p class="mt-4 text-lg leading-relaxed text-leaf">
          V období JZD se v Lysicích po stovkách kácely staré ovocné stromy. Půda byla potřeba pro velké
          hospodaření a na staleté sady nezůstal prostor ani cit. Tím se z krajiny vytratily nejen plody,
          ale i paměť místa.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-leaf">
          Paní Hedvika Horňanská se rozhodla tento stav změnit. Jejím životním posláním je vrátit ovocné
          stromy zpět do Lysic a okolí — do zahrad, kde mají domov, i do srdcí lidí, kterým záleží na
          budoucnosti krajiny.
        </p>
      </article>
      <div class="skeleton-image min-h-64">
        <span>Zde bude portrét paní Hedviky</span>
      </div>
    </div>
  </section>

  <section class="container-page py-10 md:py-14">
    <div class="mb-8 flex items-end justify-between gap-4">
      <h2 class="font-heading text-3xl text-leaf md:text-4xl">Z našeho blogu</h2>
      <a href="/blog" class="text-base font-semibold text-earth hover:text-apple">Zobrazit všechny články</a>
    </div>
    <div class="grid gap-6 md:grid-cols-3">
      {
        featuredPosts.map((post) => (
          <article class="rounded-xl border border-leaf/20 bg-white/75 p-4 shadow-sm">
            <Image
              src={post.data.previewImage ?? blogHeroDemoImage}
              alt={post.data.previewImageAlt ?? post.data.title}
              width={1200}
              height={900}
              class="mb-4 aspect-video h-auto w-full rounded-lg border border-leaf/15 object-cover"
            />
            <h3 class="font-heading text-2xl text-leaf">
              <a class="hover:text-apple" href={`/blog/${post.id}/`}>
                {post.data.title}
              </a>
            </h3>
            <p class="mt-2 text-base leading-relaxed text-leaf/95">{post.data.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section id="kontakt" class="container-page py-10 md:py-14">
    <div class="rounded-xl border border-earth/40 bg-earth/15 p-6 md:p-8">
      <h2 class="font-heading text-3xl text-leaf md:text-4xl">Kontakt</h2>
      <p class="mt-3 max-w-2xl text-lg text-leaf">
        Chcete pomoci s výsadbou, darovat stromky nebo se zapojit do obnovy sadů? Napište nám.
      </p>

      <form class="mt-6 grid gap-4 md:grid-cols-2">
        <label class="flex flex-col gap-2 text-base font-semibold text-leaf">
          Jméno
          <input
            type="text"
            name="name"
            class="rounded-md border border-leaf/40 bg-white px-3 py-2.5 text-base outline-none ring-apple/40 focus:ring"
            placeholder="Vaše jméno"
          />
        </label>
        <label class="flex flex-col gap-2 text-base font-semibold text-leaf">
          E-mail
          <input
            type="email"
            name="email"
            class="rounded-md border border-leaf/40 bg-white px-3 py-2.5 text-base outline-none ring-apple/40 focus:ring"
            placeholder="vas@email.cz"
          />
        </label>
        <label class="md:col-span-2 flex flex-col gap-2 text-base font-semibold text-leaf">
          Zpráva
          <textarea
            name="message"
            rows={5}
            class="rounded-md border border-leaf/40 bg-white px-3 py-2.5 text-base outline-none ring-apple/40 focus:ring"
            placeholder="Jak se chcete zapojit?"
          ></textarea>
        </label>
        <div class="md:col-span-2">
          <button type="submit" class="rounded-md bg-apple px-6 py-3 text-lg font-semibold text-white hover:bg-apple/90">
            Odeslat zprávu
          </button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>

---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { DEFAULT_BLOG_AUTHOR } from "../../constants/blog";
import blogHeroDemoImage from "../../assets/blog/stare-odrudy-demo.svg";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const author = post.data.author ?? DEFAULT_BLOG_AUTHOR;
const heroImage = post.data.previewImage ?? blogHeroDemoImage;
const heroImageAlt = post.data.previewImageAlt ?? post.data.title;
---

<BaseLayout title={`${post.data.title} | Návrat stromků`} description={post.data.description}>
  <article class="container-page py-12 md:py-16">
    <p class="text-sm font-semibold uppercase tracking-wide text-earth">
      {post.data.pubDate.toLocaleDateString("cs-CZ")} • {author}
    </p>
    <h1 class="mt-3 font-heading text-4xl leading-tight text-leaf md:text-5xl">{post.data.title}</h1>
    <p class="mt-4 max-w-3xl text-xl text-leaf">{post.data.description}</p>

    <Image
      src={heroImage}
      alt={heroImageAlt}
      width={1200}
      height={900}
      class="my-8 mx-auto h-auto w-full max-w-5xl rounded-lg border border-leaf/15 shadow-sm 2xl:max-w-4xl"
    />

    <div
      class="prose prose-lg flow-root max-w-none prose-headings:font-heading prose-headings:text-leaf prose-p:text-leaf prose-p:leading-relaxed prose-li:text-leaf prose-li:leading-relaxed"
    >
      <Content />
    </div>
  </article>
</BaseLayout>

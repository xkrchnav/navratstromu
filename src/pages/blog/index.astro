---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import blogHeroDemoImage from "../../assets/blog/stare-odrudy-demo.svg";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<BaseLayout title="Blog | Návrat stromků" description="Články o výsadbě stromů, starých odrůdách a péči o sady.">
  <section class="container-page py-12 md:py-16">
    <h1 class="font-heading text-4xl text-leaf md:text-5xl">Blog</h1>
    <p class="mt-3 max-w-3xl text-lg text-leaf md:text-xl">
      Praktické návody, příběhy z obnovy sadů a inspirace pro každého, kdo chce vrátit stromy zpět do
      české krajiny.
    </p>

    <div class="mt-8 space-y-5">
      {
        posts.map((post) => (
          <article class="flex flex-col-reverse gap-4 rounded-xl border border-leaf/20 bg-white/80 p-6 shadow-sm sm:flex-row sm:items-start">
            <div class="flex-1">
              <p class="text-sm font-semibold uppercase tracking-wide text-earth">
                {post.data.pubDate.toLocaleDateString("cs-CZ")}
              </p>
              <h2 class="mt-2 font-heading text-3xl text-leaf">
                <a href={`/blog/${post.id}/`} class="hover:text-apple">
                  {post.data.title}
                </a>
              </h2>
              <p class="mt-2 text-lg text-leaf">{post.data.description}</p>
            </div>
            <a href={`/blog/${post.id}/`} class="shrink-0">
              <Image
                src={post.data.previewImage ?? blogHeroDemoImage}
                alt={post.data.previewImageAlt ?? post.data.title}
                width={320}
                height={220}
                class="h-24 w-32 rounded-md border border-leaf/15 object-cover shadow-sm md:h-28 md:w-36"
              />
            </a>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

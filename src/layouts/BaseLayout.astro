---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Návrat stromků",
  description = "Příběh návratu ovocných stromů do Lysic a okolí.",
} = Astro.props;
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen antialiased">
    <header class="border-b border-leaf/35 bg-paper/95 backdrop-blur">
      <div class="container-page flex items-center justify-between py-5">
        <a href="/" class="font-heading text-2xl font-bold text-leaf">Návrat stromků</a>
        <nav class="flex items-center gap-4 md:gap-6 text-base font-semibold">
          <a class="hover:text-apple transition-colors" href="/">Domů</a>
          <a class="hover:text-apple transition-colors" href="/blog">Blog</a>
          <a class="hover:text-apple transition-colors" href="/#kontakt">Kontakt</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="mt-16 bg-earth text-paper">
      <div class="container-page py-8 text-base">
        <p>Obnova sadů v Lysicích a okolí • s úctou k půdě, paměti i budoucnosti.</p>
      </div>
    </footer>
  </body>
</html>
